{
  "name": "@shamwari/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview --port 3000",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check-types": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "size": "size-limit"
  },
  "dependencies": {
    "@shamwari/ui": "*",
    "@workos/authkit-sveltekit": "^0.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@sveltejs/adapter-vercel": "^5.5.0",
    "@sveltejs/kit": "^2.20.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/vite": "^4",
    "@types/node": "^20",
    "eslint": "^9",
    "eslint-plugin-svelte": "^3.0.0",
    "globals": "^16.0.0",
    "mode-watcher": "^1.1.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "@playwright/test": "^1.49.0",
    "@testing-library/svelte": "^5.2.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@vitest/coverage-v8": "^2.1.0",
    "jsdom": "^25.0.0",
    "size-limit": "^11.1.0",
    "@size-limit/preset-app": "^11.1.0",
    "vitest": "^2.1.0"
  },
  "size-limit": [
    {
      "name": "client entry",
      "path": ".svelte-kit/output/client/_app/immutable/entry/*.js",
      "limit": "20 KB"
    },
    {
      "name": "client total",
      "path": ".svelte-kit/output/client/_app/immutable/**/*.js",
      "limit": "150 KB"
    }
  ]
}
