# Shamwari AI — Platform App (platform.shamwari.ai)
# Copy to .env.local and fill in values

# WorkOS AuthKit — pull values from the WorkOS Dashboard.
# https://dashboard.workos.com/
WORKOS_CLIENT_ID=client_01HXXXXXXXXXXXXXXXXXXXXXXX
WORKOS_API_KEY=YOUR_WORKOS_API_KEY_HERE
# Must match a Redirect URI registered against this client.
WORKOS_REDIRECT_URI=http://localhost:3001/callback
# 32+ characters. Generate with: openssl rand -base64 32
WORKOS_COOKIE_PASSWORD=replace-with-32-or-more-random-characters

# AI Backend (Fly.io FastAPI)
AI_API_URL=https://shamwari-ai.fly.dev

# Cloudflare R2 (for file uploads from server actions)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=shamwari-assets
